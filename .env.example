# ---------------------------------------------------------------------------
# Roza Agent — environment configuration (Phase 1)
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# Values are intentionally left blank here.
# ---------------------------------------------------------------------------

# REQUIRED. Secret used to derive the AES-256-GCM key that encrypts Roza's
# private journal. Startup aborts if missing, empty, or whitespace-only.
ROZA_PRIVATE_KEY=

# REQUIRED. Credential for the OpenRouter API used by the Cognitive Engine.
# Startup aborts if missing, empty, or whitespace-only. Never logged.
OPENROUTER_API_KEY=

# Optional. OpenRouter model id. Default: openai/gpt-4o-mini
OPENROUTER_MODEL=

# Optional. IANA timezone for the Active_Window and recorded timestamps.
# Default: Africa/Kinshasa
ROZA_TIMEZONE=

# Optional. Active_Window start time, 24-hour HH:MM (00:00–23:59).
# Default: 07:00
ACTIVE_WINDOW_START=

# Optional. Active_Window end time, 24-hour HH:MM (00:00–23:59).
# Default: 22:00
ACTIVE_WINDOW_END=

# Optional. Durable data directory holding roza_mind.sqlite.
# Default: /app/data
ROZA_DATA_DIR=

# Optional. Journal encryption key version label recorded with each entry.
# Default: v1
ROZA_KEY_VERSION=

# ---------------------------------------------------------------------------
# Roza Agent — channel configuration (Phase 2: Telegram & Mail)
# All values are intentionally left blank here. NEVER commit real secrets.
# Credentials are read ONLY from the environment and are never logged or
# persisted to the database or profile store.
# ---------------------------------------------------------------------------

# --- Telegram channel (free Telegram Bot API via grammY) -------------------

# Optional. "true"/"false". Enables the Telegram channel. Default: false.
TELEGRAM_ENABLED=

# Secret. REQUIRED when TELEGRAM_ENABLED=true. Bot API token from BotFather.
# Startup aborts (non-zero exit) if enabled and this is missing/empty/blank.
# Never logged.
TELEGRAM_BOT_TOKEN=

# Optional. Comma-separated allowlist of permitted Telegram chat/user ids.
# When enabled with no allowlist, the documented default is allow-all.
TELEGRAM_ALLOWLIST=

# --- Mail channel (open IMAP read + SMTP send) -----------------------------

# Optional. "true"/"false". Enables the email channel. Default: false.
MAIL_ENABLED=

# REQUIRED when MAIL_ENABLED=true. IMAP (inbound) connection settings.
# Startup aborts (non-zero exit) if enabled and any of these is missing/blank.
# MAIL_IMAP_PASSWORD is a secret and is never logged.
MAIL_IMAP_HOST=
MAIL_IMAP_PORT=
MAIL_IMAP_USER=
MAIL_IMAP_PASSWORD=

# REQUIRED when MAIL_ENABLED=true. SMTP (outbound) connection settings.
# Startup aborts (non-zero exit) if enabled and any of these is missing/blank.
# MAIL_SMTP_PASSWORD is a secret and is never logged.
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=
MAIL_SMTP_USER=
MAIL_SMTP_PASSWORD=

# Optional. Comma-separated allowlist of permitted sender email addresses.
# When enabled with no allowlist, the documented default is allow-all.
MAIL_ALLOWLIST=
# ---------------------------------------------------------------------------
# Roza Agent — voice & telephony configuration (Phase 3: Voice & Telephony)
# All values are intentionally left blank here. NEVER commit real secrets.
# Credentials are read ONLY from the environment and are never logged or
# persisted to the database or profile store.
# ---------------------------------------------------------------------------

# Optional. "true"/"false". Enables the voice/telephony channel. Default: false.
VOICE_ENABLED=

# --- SIP trunk credentials -------------------------------------------------
# REQUIRED when VOICE_ENABLED=true. SIP trunk connection settings used to
# register with the upstream provider. Startup aborts (non-zero exit) if voice
# is enabled and any of these is missing/empty/blank. SIP_PASSWORD is a secret;
# these credentials are never logged.
SIP_HOST=
SIP_PORT=
SIP_USER=
SIP_PASSWORD=
SIP_REALM=

# --- Caller access control -------------------------------------------------

# Optional. Comma-separated allowlist of permitted caller identities (numbers).
# When empty, VOICE_DEFAULT_ACCESS is applied to all callers.
VOICE_ALLOWLIST=

# Optional. Access decision for callers not on VOICE_ALLOWLIST.
# 'reject' | 'allow'. Default: reject.
VOICE_DEFAULT_ACCESS=

# Optional. Handling of inbound calls received outside the Active_Window
# (quiet hours). 'reject' | 'answer_busy' | 'take_message'.
# Default: take_message.
VOICE_QUIET_HOURS_INBOUND=

# --- Text-to-speech (TTS) --------------------------------------------------

# Optional. TTS engine identifier. Default: piper.
TTS_ENGINE=

# Optional. TTS voice identifier. Default: en_US-amy-medium.
TTS_VOICE=

# Optional. TTS model identifier. Default: en_US-amy-medium.
TTS_MODEL=

# Optional. Maximum characters per spoken reply (longer replies are truncated).
# Default: 1000.
TTS_MAX_REPLY_CHARS=

# Optional. TTS synthesis latency budget in milliseconds. Default: 5000.
TTS_LATENCY_MS=

# --- Speech-to-text (STT) --------------------------------------------------

# Optional. STT engine identifier. Default: whisper.cpp.
STT_ENGINE=

# Optional. STT model identifier. Default: ggml-base.en.
STT_MODEL=

# Optional. STT transcription latency budget in milliseconds. Default: 5000.
STT_LATENCY_MS=

# --- Voice timing budgets --------------------------------------------------

# Optional. End-to-end voice response latency budget in milliseconds.
# Default: 8000.
VOICE_RESPONSE_LATENCY_MS=

# Optional. Inbound ring timeout in milliseconds before fallback handling.
# Default: 30000.
VOICE_RING_TIMEOUT_MS=

# --- Asterisk container (separate service) ---------------------------------
# NOTE: The Asterisk container additionally consumes ARI_* and AUDIOSOCKET_*
# placeholders. Those variables are documented in docker/asterisk/README.md
# and are not consumed directly by the Roza Agent process.
