# ---------------------------------------------------------------------------
# Roza Agent — environment configuration (Phase 1)
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# Values are intentionally left blank here.
# ---------------------------------------------------------------------------

# REQUIRED. Secret used to derive the AES-256-GCM key that encrypts Roza's
# private journal. Startup aborts if missing, empty, or whitespace-only.
ROZA_PRIVATE_KEY=

# REQUIRED. Credential for the OpenRouter API used by the Cognitive Engine.
# Startup aborts if missing, empty, or whitespace-only. Never logged.
OPENROUTER_API_KEY=

# Optional. OpenRouter model id. Default: openai/gpt-4o-mini
OPENROUTER_MODEL=

# Optional. IANA timezone for the Active_Window and recorded timestamps.
# Default: Africa/Kinshasa
ROZA_TIMEZONE=

# Optional. Active_Window start time, 24-hour HH:MM (00:00–23:59).
# Default: 07:00
ACTIVE_WINDOW_START=

# Optional. Active_Window end time, 24-hour HH:MM (00:00–23:59).
# Default: 22:00
ACTIVE_WINDOW_END=

# Optional. Durable data directory holding roza_mind.sqlite.
# Default: /app/data
ROZA_DATA_DIR=

# Optional. Journal encryption key version label recorded with each entry.
# Default: v1
ROZA_KEY_VERSION=

# ---------------------------------------------------------------------------
# Roza Agent — channel configuration (Phase 2: Telegram & Mail)
# All values are intentionally left blank here. NEVER commit real secrets.
# Credentials are read ONLY from the environment and are never logged or
# persisted to the database or profile store.
# ---------------------------------------------------------------------------

# --- Telegram channel (free Telegram Bot API via grammY) -------------------

# Optional. "true"/"false". Enables the Telegram channel. Default: false.
TELEGRAM_ENABLED=

# Secret. REQUIRED when TELEGRAM_ENABLED=true. Bot API token from BotFather.
# Startup aborts (non-zero exit) if enabled and this is missing/empty/blank.
# Never logged.
TELEGRAM_BOT_TOKEN=

# Optional. Comma-separated allowlist of permitted Telegram chat/user ids.
# When enabled with no allowlist, the documented default is allow-all.
TELEGRAM_ALLOWLIST=

# --- Mail channel (open IMAP read + SMTP send) -----------------------------

# Optional. "true"/"false". Enables the email channel. Default: false.
MAIL_ENABLED=

# REQUIRED when MAIL_ENABLED=true. IMAP (inbound) connection settings.
# Startup aborts (non-zero exit) if enabled and any of these is missing/blank.
# MAIL_IMAP_PASSWORD is a secret and is never logged.
MAIL_IMAP_HOST=
MAIL_IMAP_PORT=
MAIL_IMAP_USER=
MAIL_IMAP_PASSWORD=

# REQUIRED when MAIL_ENABLED=true. SMTP (outbound) connection settings.
# Startup aborts (non-zero exit) if enabled and any of these is missing/blank.
# MAIL_SMTP_PASSWORD is a secret and is never logged.
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=
MAIL_SMTP_USER=
MAIL_SMTP_PASSWORD=

# Optional. Comma-separated allowlist of permitted sender email addresses.
# When enabled with no allowlist, the documented default is allow-all.
MAIL_ALLOWLIST=
# ---------------------------------------------------------------------------
# Roza Agent — voice & telephony configuration (Phase 3: Voice & Telephony)
# All values are intentionally left blank here. NEVER commit real secrets.
# Credentials are read ONLY from the environment and are never logged or
# persisted to the database or profile store.
# ---------------------------------------------------------------------------

# Optional. "true"/"false". Enables the voice/telephony channel. Default: false.
VOICE_ENABLED=

# --- SIP trunk credentials -------------------------------------------------
# REQUIRED when VOICE_ENABLED=true. SIP trunk connection settings used to
# register with the upstream provider. Startup aborts (non-zero exit) if voice
# is enabled and any of these is missing/empty/blank. SIP_PASSWORD is a secret;
# these credentials are never logged.
SIP_HOST=
SIP_PORT=
SIP_USER=
SIP_PASSWORD=
SIP_REALM=

# --- Caller access control -------------------------------------------------

# Optional. Comma-separated allowlist of permitted caller identities (numbers).
# When empty, VOICE_DEFAULT_ACCESS is applied to all callers.
VOICE_ALLOWLIST=

# Optional. Access decision for callers not on VOICE_ALLOWLIST.
# 'reject' | 'allow'. Default: reject.
VOICE_DEFAULT_ACCESS=

# Optional. Handling of inbound calls received outside the Active_Window
# (quiet hours). 'reject' | 'answer_busy' | 'take_message'.
# Default: take_message.
VOICE_QUIET_HOURS_INBOUND=

# --- Text-to-speech (TTS) --------------------------------------------------

# Optional. TTS engine identifier. Default: piper.
TTS_ENGINE=

# Optional. TTS voice identifier. Default: en_US-amy-medium.
TTS_VOICE=

# Optional. TTS model identifier. Default: en_US-amy-medium.
TTS_MODEL=

# Optional. Maximum characters per spoken reply (longer replies are truncated).
# Default: 1000.
TTS_MAX_REPLY_CHARS=

# Optional. TTS synthesis latency budget in milliseconds. Default: 5000.
TTS_LATENCY_MS=

# --- Speech-to-text (STT) --------------------------------------------------

# Optional. STT engine identifier. Default: whisper.cpp.
STT_ENGINE=

# Optional. STT model identifier. Default: ggml-base.en.
STT_MODEL=

# Optional. STT transcription latency budget in milliseconds. Default: 5000.
STT_LATENCY_MS=

# --- Voice timing budgets --------------------------------------------------

# Optional. End-to-end voice response latency budget in milliseconds.
# Default: 8000.
VOICE_RESPONSE_LATENCY_MS=

# Optional. Inbound ring timeout in milliseconds before fallback handling.
# Default: 30000.
VOICE_RING_TIMEOUT_MS=

# --- Asterisk container (separate service) ---------------------------------
# NOTE: The Asterisk container additionally consumes ARI_* and AUDIOSOCKET_*
# placeholders. Those variables are documented in docker/asterisk/README.md
# and are not consumed directly by the Roza Agent process.
# ---------------------------------------------------------------------------
# Roza Agent — avatar video & live streaming (Phase 4: Avatar_Channel)
# All values are intentionally left blank here. NEVER commit real secrets.
# Credentials are read ONLY from the environment and are never logged or
# persisted to the database or profile store.
#
# HONESTY NOTES (documented deployment constraints, not hard runtime gates):
#   * Real-time animated lip-synced avatar synthesis generally needs a GPU.
#     The Avatar_Renderer runs as a SEPARATE sidecar process (see
#     docker/avatar-renderer/) — the Node service performs no in-process ML and
#     orchestrates the renderer over AVATAR_RENDERER_ENDPOINT. On CPU-only hosts
#     expect the latency budget to be exceeded and the audio-only fallback to
#     engage.
#   * Google Meet headless automation (Playwright/Chromium) is fragile and
#     carries Terms-of-Service risk; reliable joins typically need a real
#     Google Workspace account. Keep MEET_ENABLED=false unless you accept this.
#   * assets/roza-avatar.png is a PLACEHOLDER portrait — replace it with real
#     artwork before any production appearance.
# ---------------------------------------------------------------------------

# Optional. "true"/"false". Enables the avatar presence/output capability.
# The avatar is a configuration-gated presence capability, NOT a conversation
# channel — when false the capability stays completely inert. Default: false.
AVATAR_ENABLED=

# --- Avatar video format (Avatar_Video_Format) -----------------------------
# Optional. The video format the renderer must emit and the virtual devices
# consume. All parse with documented defaults so an enabled capability always
# has a complete, tunable config.

# Optional. Video_Frame width in pixels. Default: 512.
AVATAR_WIDTH=

# Optional. Video_Frame height in pixels. Default: 512.
AVATAR_HEIGHT=

# Optional. Frame rate in frames per second. Default: 25.
AVATAR_FPS=

# Optional. Pixel/encoding format. 'rgba' | 'yuv420p' | 'nv12'.
# Default: yuv420p.
AVATAR_PIXEL_FORMAT=

# --- Synthesis latency budget ----------------------------------------------

# Optional. Render latency budget in milliseconds (time-to-first-frame). On
# overrun the connector degrades gracefully to the audio-only fallback rather
# than blocking the reply. Default: 4000.
AVATAR_RENDER_LATENCY_MS=

# --- Renderer sidecar (NOT secrets) ----------------------------------------

# Optional. HTTP/IPC endpoint of the external Avatar_Renderer sidecar that the
# Node service orchestrates. Not a secret. Example: http://avatar-renderer:8080
AVATAR_RENDERER_ENDPOINT=

# Optional. Renderer engine label (e.g. the lip-sync engine in use). Not a
# secret; used for diagnostics/audit only.
AVATAR_ENGINE=

# --- Host virtual devices (NOT secrets) ------------------------------------
# NOTE: These are host-level virtual-device names the operator must provision
# (e.g. a v4l2loopback camera and a PipeWire null-sink microphone). They are
# not secrets. See docker-compose.yml and docker/avatar-renderer/ notes.

# Optional. Virtual_Camera device name fed by the renderer (v4l2loopback).
AVATAR_CAMERA_DEVICE=

# Optional. Virtual_Microphone device/sink name fed the reply audio (PipeWire).
AVATAR_MIC_DEVICE=

# --- Google Meet presence (sub-capability) ---------------------------------
# Headless Meet automation is fragile and ToS-risky (see honesty notes above).
# MEET_CONSENT MUST be "true" before the connector will ever join a meeting.

# Optional. "true"/"false". Enables the Google Meet presence sub-capability.
# Default: false.
MEET_ENABLED=

# Optional. "true"/"false". Recorded consent gate — the connector refuses to
# join any meeting unless this is "true". Default: false.
MEET_CONSENT=

# Secret. REQUIRED when MEET_ENABLED=true. Meet_Credentials account/login.
# Startup aborts (non-zero exit) if Meet is enabled and this is missing/blank.
# Reported by NAME only on failure; the value is never logged.
MEET_ACCOUNT=

# Secret. REQUIRED when MEET_ENABLED=true. Meet_Credentials password.
# Startup aborts (non-zero exit) if Meet is enabled and this is missing/blank.
# Reported by NAME only on failure; the value is never logged.
MEET_PASSWORD=

# --- RTMP live streaming (sub-capability) ----------------------------------

# Optional. "true"/"false". Enables the live RTMP streaming sub-capability.
# Default: false.
STREAM_ENABLED=

# Optional. RTMP ingest URL the combined A/V stream is published to. The URL
# is treated as untrusted data and passed only to the transport, never executed
# as a command. Example: rtmp://ingest.example/live
RTMP_URL=

# Secret. REQUIRED when STREAM_ENABLED=true. Stream_Key for the RTMP ingest.
# Startup aborts (non-zero exit) if streaming is enabled and this is
# missing/blank. Reported by NAME only on failure; the value is NEVER logged.
STREAM_KEY=
# ---------------------------------------------------------------------------
# Roza Agent — X / Twitter (browser automation) (Phase 5: X_Capability)
# All values are intentionally left blank here. NEVER commit real secrets.
# Credentials are read ONLY from the environment and are never logged or
# persisted to the database or profile store.
#
# HONESTY NOTES (documented operator constraints, not hard runtime gates):
#   * Browser automation of X is fragile, may conflict with X's Terms of
#     Service, and may trigger anti-bot defenses. Reliable operation needs a
#     real X account and active monitoring. Keep X_ENABLED=false unless you
#     accept this risk.
#   * Roza posts as an individual thinker in her own name, with NO Opays
#     marketing — no sales jargon, no corporate promotion.
#   * The X_Session_State file contents (X_STORAGE_STATE_PATH) are sensitive:
#     they grant authenticated access and are NEVER logged.
#   * Phase 5 completes Roza's social architecture via browser automation under
#     the open-source-first rule (Playwright, Apache-2.0 — NO paid X/Twitter
#     API). X is a presence/autonomy capability, not a conversation channel.
# ---------------------------------------------------------------------------

# Optional. "true"/"false". Enables the X presence/autonomy capability.
# When false the capability stays completely inert and never aborts startup
# even if X_USERNAME/X_PASSWORD are absent. Default: false.
X_ENABLED=

# Secret. REQUIRED when X_ENABLED=true. X account login (username/handle).
# Startup aborts (non-zero exit) if X is enabled and this is missing/empty/
# blank. Reported by NAME only on failure; the value is never logged.
X_USERNAME=

# Secret. REQUIRED when X_ENABLED=true. X account password.
# Startup aborts (non-zero exit) if X is enabled and this is missing/empty/
# blank. Reported by NAME only on failure; the value is never logged.
X_PASSWORD=

# Optional. Durable path to the X_Session_State file used to restore an
# authenticated browser session and avoid re-login. Contents are sensitive
# and never logged. Default: ${ROZA_DATA_DIR}/x_storage_state.json.
X_STORAGE_STATE_PATH=

# Optional. Minutes between autonomous X runs (driven from the in-window
# scheduler tick; no X_Action ever occurs during Quiet_Hours). Default: 60.
X_AUTONOMY_INTERVAL_MINUTES=

# Optional. Maximum number of Roza_Posts permitted per timezone-local calendar
# day. Further posts that day are denied. Default: 10.
X_DAILY_POST_LIMIT=

# Optional. Minimum spacing between X_Actions in milliseconds. Actions closer
# than this are deferred. Default: 600000 (10 minutes).
X_ACTION_SPACING_MS=

# Optional. Maximum number of Hot_Topics selected from the Timeline per run.
# Default: 3.
X_MAX_TOPICS=

# Optional. Maximum characters per post/reply; longer content is composed
# within this bound. Default: 280.
X_MAX_POST_CHARS=

# Optional. "true"/"false". Dry-run mode — Roza formulates and audits content
# but never publishes to X. Default: false.
X_DRY_RUN=
